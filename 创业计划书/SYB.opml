        </outline>
        <outline text="不足" _mubu_text="%3Cspan%3E%E4%B8%8D%E8%B6%B3%3C/span%3E" _note="" _mubu_note="">
          <outline text="没有建立上游和下游的信息流，无法将自己的想法清晰的表述出来" _mubu_text="%3Cspan%3E%E6%B2%A1%E6%9C%89%E5%BB%BA%E7%AB%8B%E4%B8%8A%E6%B8%B8%E5%92%8C%E4%B8%8B%E6%B8%B8%E7%9A%84%E4%BF%A1%E6%81%AF%E6%B5%81%EF%BC%8C%E6%97%A0%E6%B3%95%E5%B0%86%E8%87%AA%E5%B7%B1%E7%9A%84%E6%83%B3%E6%B3%95%E6%B8%85%E6%99%B0%E7%9A%84%E8%A1%A8%E8%BF%B0%E5%87%BA%E6%9D%A5%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="" _mubu_text="" _note="" _mubu_note=""/>
        </outline>
      </outline>
      <outline text="怎样能够开发自己作为企业家的能力" _mubu_text="%3Cspan%3E%E6%80%8E%E6%A0%B7%E8%83%BD%E5%A4%9F%E5%BC%80%E5%8F%91%E8%87%AA%E5%B7%B1%E4%BD%9C%E4%B8%BA%E4%BC%81%E4%B8%9A%E5%AE%B6%E7%9A%84%E8%83%BD%E5%8A%9B%3C/span%3E" _note="" _mubu_note=""/>
    </outline>
    <outline text="" _mubu_text="" _note="" _mubu_note=""/>
    <outline text="四、筛选你的企业构思" _mubu_text="%3Cspan%3E%E5%9B%9B%E3%80%81%E7%AD%9B%E9%80%89%E4%BD%A0%E7%9A%84%E4%BC%81%E4%B8%9A%E6%9E%84%E6%80%9D%3C/span%3E" _note="" _mubu_note="">
      <outline text="（一）、了解你的顾客" _mubu_text="%3Cspan%3E%EF%BC%88%E4%B8%80%EF%BC%89%E3%80%81%E4%BA%86%E8%A7%A3%E4%BD%A0%E7%9A%84%E9%A1%BE%E5%AE%A2%3C/span%3E" _note="" _mubu_note="">
        <outline text="1. 了解顾客的意义" _mubu_text="%3Cspan%3E1.%20%E4%BA%86%E8%A7%A3%E9%A1%BE%E5%AE%A2%E7%9A%84%E6%84%8F%E4%B9%89%3C/span%3E" _note="" _mubu_note="">
          <outline text="顾客需求" _mubu_text="%3Cspan%3E%E9%A1%BE%E5%AE%A2%E9%9C%80%E6%B1%82%3C/span%3E" _note="" _mubu_note="">
            <outline text="反向思维：将自己作为消费者查验顾客和市场需求的切入点" _mubu_text="%3Cspan%3E%E5%8F%8D%E5%90%91%E6%80%9D%E7%BB%B4%EF%BC%9A%E5%B0%86%E8%87%AA%E5%B7%B1%E4%BD%9C%E4%B8%BA%E6%B6%88%E8%B4%B9%E8%80%85%E6%9F%A5%E9%AA%8C%E9%A1%BE%E5%AE%A2%E5%92%8C%E5%B8%82%E5%9C%BA%E9%9C%80%E6%B1%82%E7%9A%84%E5%88%87%E5%85%A5%E7%82%B9%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="没有顾客，你的企业就会倒闭" _mubu_text="%3Cspan%20class=%22text-color-red%22%3E%E6%B2%A1%E6%9C%89%E9%A1%BE%E5%AE%A2%EF%BC%8C%E4%BD%A0%E7%9A%84%E4%BC%81%E4%B8%9A%E5%B0%B1%E4%BC%9A%E5%80%92%E9%97%AD%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
        </outline>
        <outline text="2. 确定目标顾客" _mubu_text="%3Cspan%3E2.%20%E7%A1%AE%E5%AE%9A%E7%9B%AE%E6%A0%87%E9%A1%BE%E5%AE%A2%3C/span%3E" _note="" _mubu_note="">
          <outline text="客户粘性：一个老客户，胜过十个新客户" _mubu_text="%3Cspan%3E%E5%AE%A2%E6%88%B7%E7%B2%98%E6%80%A7%EF%BC%9A%E4%B8%80%E4%B8%AA%E8%80%81%E5%AE%A2%E6%88%B7%EF%BC%8C%E8%83%9C%E8%BF%87%E5%8D%81%E4%B8%AA%E6%96%B0%E5%AE%A2%E6%88%B7%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="抓住客户群体的特点和范围" _mubu_text="%3Cspan%3E%E6%8A%93%E4%BD%8F%E5%AE%A2%E6%88%B7%E7%BE%A4%E4%BD%93%E7%9A%84%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3E%E7%89%B9%E7%82%B9%E5%92%8C%E8%8C%83%E5%9B%B4%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="3. 了解顾客的有关信息" _mubu_text="%3Cspan%3E3.%20%E4%BA%86%E8%A7%A3%E9%A1%BE%E5%AE%A2%E7%9A%84%E6%9C%89%E5%85%B3%E4%BF%A1%E6%81%AF%3C/span%3E" _note="" _mubu_note="">
          <outline text="——  列出产品或服务清单，划分顾客层次和潜在顾客需求" _mubu_text="%3Cspan%3E%E2%80%94%E2%80%94%20%20%E5%88%97%E5%87%BA%E4%BA%A7%E5%93%81%E6%88%96%E6%9C%8D%E5%8A%A1%E6%B8%85%E5%8D%95%EF%BC%8C%E5%88%92%E5%88%86%E9%A1%BE%E5%AE%A2%E5%B1%82%E6%AC%A1%E5%92%8C%E6%BD%9C%E5%9C%A8%E9%A1%BE%E5%AE%A2%E9%9C%80%E6%B1%82%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="4. 收集顾客信息的方法" _mubu_text="%3Cspan%3E4.%20%E6%94%B6%E9%9B%86%E9%A1%BE%E5%AE%A2%E4%BF%A1%E6%81%AF%E7%9A%84%E6%96%B9%E6%B3%95%3C/span%3E" _note="" _mubu_note="">
          <outline text="主观意识" _mubu_text="%3Cspan%3E%E4%B8%BB%E8%A7%82%E6%84%8F%E8%AF%86%3C/span%3E" _note="" _mubu_note="">
            <outline text="经验判断法" _mubu_text="%3Cspan%3E%E7%BB%8F%E9%AA%8C%E5%88%A4%E6%96%AD%E6%B3%95%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="观察法" _mubu_text="%3Cspan%3E%E8%A7%82%E5%AF%9F%E6%B3%95%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="客观评价（从0开始）" _mubu_text="%3Cspan%3E%E5%AE%A2%E8%A7%82%E8%AF%84%E4%BB%B7%EF%BC%88%E4%BB%8E0%E5%BC%80%E5%A7%8B%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
            <outline text="访谈法" _mubu_text="%3Cspan%3E%E8%AE%BF%E8%B0%88%E6%B3%95%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="问卷法" _mubu_text="%3Cspan%3E%E9%97%AE%E5%8D%B7%E6%B3%95%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
        </outline>
      </outline>
      <outline text="（二）、了解你的竞争对手" _mubu_text="%3Cspan%3E%EF%BC%88%E4%BA%8C%EF%BC%89%E3%80%81%E4%BA%86%E8%A7%A3%E4%BD%A0%E7%9A%84%E7%AB%9E%E4%BA%89%E5%AF%B9%E6%89%8B%3C/span%3E" _note="" _mubu_note="">
        <outline text="1. 了解竞争对手的意义" _mubu_text="%3Cspan%3E1.%20%E4%BA%86%E8%A7%A3%E7%AB%9E%E4%BA%89%E5%AF%B9%E6%89%8B%E7%9A%84%E6%84%8F%E4%B9%89%3C/span%3E" _note="" _mubu_note="">
          <outline text="通过了解竞争对手" _mubu_text="%3Cspan%3E%E9%80%9A%E8%BF%87%E4%BA%86%E8%A7%A3%E7%AB%9E%E4%BA%89%E5%AF%B9%E6%89%8B%3C/span%3E" _note="" _mubu_note="">
            <outline text="产品、服务、经营方式" _mubu_text="%3Cspan%3E%E4%BA%A7%E5%93%81%E3%80%81%E6%9C%8D%E5%8A%A1%E3%80%81%E7%BB%8F%E8%90%A5%E6%96%B9%E5%BC%8F%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="聚集效应" _mubu_text="%3Cspan%3E%E8%81%9A%E9%9B%86%E6%95%88%E5%BA%94%3C/span%3E" _note="" _mubu_note="">
            <outline text="客源过来后，经营怎么样就各凭本事了" _mubu_text="%3Cspan%3E%E5%AE%A2%E6%BA%90%E8%BF%87%E6%9D%A5%E5%90%8E%EF%BC%8C%E7%BB%8F%E8%90%A5%E6%80%8E%E4%B9%88%E6%A0%B7%E5%B0%B1%E5%90%84%E5%87%AD%E6%9C%AC%E4%BA%8B%E4%BA%86%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
        </outline>
        <outline text="2. 了解竞争对手的相关信息" _mubu_text="%3Cspan%3E2.%20%E4%BA%86%E8%A7%A3%E7%AB%9E%E4%BA%89%E5%AF%B9%E6%89%8B%E7%9A%84%E7%9B%B8%E5%85%B3%E4%BF%A1%E6%81%AF%3C/span%3E" _note="" _mubu_note="">
          <outline text="成功的优势是什么" _mubu_text="%3Cspan%3E%E6%88%90%E5%8A%9F%E7%9A%84%E4%BC%98%E5%8A%BF%E6%98%AF%E4%BB%80%E4%B9%88%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="人无我有；人有我优；人优我转" _mubu_text="%3Cspan%20class=%22bold%20text-color-red%22%3E%E4%BA%BA%E6%97%A0%E6%88%91%E6%9C%89%EF%BC%9B%E4%BA%BA%E6%9C%89%E6%88%91%E4%BC%98%EF%BC%9B%E4%BA%BA%E4%BC%98%E6%88%91%E8%BD%AC%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
      </outline>
      <outline text="（三）评估你的市场" _mubu_text="%3Cspan%3E%EF%BC%88%E4%B8%89%EF%BC%89%E8%AF%84%E4%BC%B0%E4%BD%A0%E7%9A%84%E5%B8%82%E5%9C%BA%3C/span%3E" _note="" _mubu_note="">
        <outline text="产品" _mubu_text="%3Cspan%3E%E4%BA%A7%E5%93%81%3C/span%3E" _note="" _mubu_note="">
          <outline text="核心产品" _mubu_text="%3Cspan%3E%E6%A0%B8%E5%BF%83%E4%BA%A7%E5%93%81%3C/span%3E" _note="" _mubu_note="">
            <outline text="如手机" _mubu_text="%3Cspan%3E%E5%A6%82%E6%89%8B%E6%9C%BA%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="形式产品" _mubu_text="%3Cspan%3E%E5%BD%A2%E5%BC%8F%E4%BA%A7%E5%93%81%3C/span%3E" _note="" _mubu_note="">
            <outline text="如手机壳、手机膜" _mubu_text="%3Cspan%3E%E5%A6%82%E6%89%8B%E6%9C%BA%E5%A3%B3%E3%80%81%E6%89%8B%E6%9C%BA%E8%86%9C%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="延伸产品" _mubu_text="%3Cspan%3E%E5%BB%B6%E4%BC%B8%E4%BA%A7%E5%93%81%3C/span%3E" _note="" _mubu_note="">
            <outline text="售后保障、定期保养" _mubu_text="%3Cspan%3E%E5%94%AE%E5%90%8E%E4%BF%9D%E9%9A%9C%E3%80%81%E5%AE%9A%E6%9C%9F%E4%BF%9D%E5%85%BB%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="受顾客青睐的原因" _mubu_text="%3Cspan%3E%E5%8F%97%E9%A1%BE%E5%AE%A2%E9%9D%92%E7%9D%90%E7%9A%84%E5%8E%9F%E5%9B%A0%3C/span%3E" _note="" _mubu_note="">
            <outline text="产品特征-特色" _mubu_text="%3Cspan%3E%E4%BA%A7%E5%93%81%E7%89%B9%E5%BE%81-%E7%89%B9%E8%89%B2%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="产品展现形式 ---&gt; 提供情绪价值" _mubu_text="%3Cspan%3E%E4%BA%A7%E5%93%81%E5%B1%95%E7%8E%B0%E5%BD%A2%E5%BC%8F%20---&amp;gt;%20%E6%8F%90%E4%BE%9B%E6%83%85%E7%BB%AA%E4%BB%B7%E5%80%BC%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
        </outline>
        <outline text="价格" _mubu_text="%3Cspan%3E%E4%BB%B7%E6%A0%BC%3C/span%3E" _note="" _mubu_note="">
          <outline text="①定价目标" _mubu_text="%3Cspan%3E%E2%91%A0%E5%AE%9A%E4%BB%B7%E7%9B%AE%E6%A0%87%3C/span%3E" _note="" _mubu_note="">
            <outline text="实现四个目的" _mubu_text="%3Cspan%3E%E5%AE%9E%E7%8E%B0%E5%9B%9B%E4%B8%AA%E7%9B%AE%E7%9A%84%3C/span%3E" _note="" _mubu_note="">
              <outline text="达到预期利润" _mubu_text="%3Cspan%3E%E8%BE%BE%E5%88%B0%E9%A2%84%E6%9C%9F%E5%88%A9%E6%B6%A6%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="适应竞争" _mubu_text="%3Cspan%3E%E9%80%82%E5%BA%94%E7%AB%9E%E4%BA%89%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="我们需要知道的内容" _mubu_text="%3Cspan%3E%E6%88%91%E4%BB%AC%E9%9C%80%E8%A6%81%E7%9F%A5%E9%81%93%E7%9A%84%E5%86%85%E5%AE%B9%3C/span%3E" _note="" _mubu_note="">
              <outline text="需求" _mubu_text="%3Cspan%3E%E9%9C%80%E6%B1%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="企业目标" _mubu_text="%3Cspan%3E%E4%BC%81%E4%B8%9A%E7%9B%AE%E6%A0%87%3C/span%3E" _note="" _mubu_note="">
                <outline text="价格占据市场 还是 实现利润" _mubu_text="%3Cspan%20class=%22bold%22%3E%E4%BB%B7%E6%A0%BC%E5%8D%A0%E6%8D%AE%E5%B8%82%E5%9C%BA%3C/span%3E%3Cspan%3E%20%E8%BF%98%E6%98%AF%20%3C/span%3E%3Cspan%20class=%22bold%22%3E%E5%AE%9E%E7%8E%B0%E5%88%A9%E6%B6%A6%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
              <outline text="成本核算" _mubu_text="%3Cspan%20class=%22bold%20text-color-purple%22%3E%E6%88%90%E6%9C%AC%E6%A0%B8%E7%AE%97%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
          <outline text="②定价策略" _mubu_text="%3Cspan%3E%E2%91%A1%E5%AE%9A%E4%BB%B7%E7%AD%96%E7%95%A5%3C/span%3E" _note="" _mubu_note="">
            <outline text="根据顾客需求的程度来判断是高价策略还是低价策略" _mubu_text="%3Cspan%3E%E6%A0%B9%E6%8D%AE%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3E%E9%A1%BE%E5%AE%A2%E9%9C%80%E6%B1%82%E7%9A%84%E7%A8%8B%E5%BA%A6%3C/span%3E%3Cspan%3E%E6%9D%A5%E5%88%A4%E6%96%AD%E6%98%AF%E9%AB%98%E4%BB%B7%E7%AD%96%E7%95%A5%E8%BF%98%E6%98%AF%E4%BD%8E%E4%BB%B7%E7%AD%96%E7%95%A5%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="折扣定价" _mubu_text="%3Cspan%3E%E6%8A%98%E6%89%A3%E5%AE%9A%E4%BB%B7%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="竞争参照定价法" _mubu_text="%3Cspan%3E%E7%AB%9E%E4%BA%89%E5%8F%82%E7%85%A7%E5%AE%9A%E4%BB%B7%E6%B3%95%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="优势定价法" _mubu_text="%3Cspan%3E%E4%BC%98%E5%8A%BF%E5%AE%9A%E4%BB%B7%E6%B3%95%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="季节定价法" _mubu_text="%3Cspan%3E%E5%AD%A3%E8%8A%82%E5%AE%9A%E4%BB%B7%E6%B3%95%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
        </outline>
        <outline text="地点" _mubu_text="%3Cspan%3E%E5%9C%B0%E7%82%B9%3C/span%3E" _note="" _mubu_note="">
          <outline text="零售或服务业" _mubu_text="%3Cspan%3E%E9%9B%B6%E5%94%AE%E6%88%96%E6%9C%8D%E5%8A%A1%E4%B8%9A%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="制造业" _mubu_text="%3Cspan%3E%E5%88%B6%E9%80%A0%E4%B8%9A%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="林、牧、渔业" _mubu_text="%3Cspan%3E%E6%9E%97%E3%80%81%E7%89%A7%E3%80%81%E6%B8%94%E4%B8%9A%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="促销" _mubu_text="%3Cspan%3E%E4%BF%83%E9%94%80%3C/span%3E" _note="" _mubu_note="">
          <outline text="方式" _mubu_text="%3Cspan%3E%E6%96%B9%E5%BC%8F%3C/span%3E" _note="" _mubu_note="">
            <outline text="广告、人员推销、公共关系（宣传、赞助）" _mubu_text="%3Cspan%3E%E5%B9%BF%E5%91%8A%E3%80%81%E4%BA%BA%E5%91%98%E6%8E%A8%E9%94%80%E3%80%81%E5%85%AC%E5%85%B1%E5%85%B3%E7%B3%BB%EF%BC%88%E5%AE%A3%E4%BC%A0%E3%80%81%E8%B5%9E%E5%8A%A9%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="评估市场：预测你的销售量" _mubu_text="%3Cspan%3E%E8%AF%84%E4%BC%B0%E5%B8%82%E5%9C%BA%EF%BC%9A%E9%A2%84%E6%B5%8B%E4%BD%A0%E7%9A%84%E9%94%80%E5%94%AE%E9%87%8F%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="创业初期，销售量都不会太大" _mubu_text="%3Cspan%3E%E5%88%9B%E4%B8%9A%E5%88%9D%E6%9C%9F%EF%BC%8C%E9%94%80%E5%94%AE%E9%87%8F%E9%83%BD%E4%B8%8D%E4%BC%9A%E5%A4%AA%E5%A4%A7%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
      </outline>
    </outline>
    <outline text="五、分析你的企业的构思" _mubu_text="%3Cspan%3E%E4%BA%94%E3%80%81%E5%88%86%E6%9E%90%E4%BD%A0%E7%9A%84%E4%BC%81%E4%B8%9A%E7%9A%84%E6%9E%84%E6%80%9D%3C/span%3E" _note="" _mubu_note="">
      <outline text="SWOT（静态分析法）" _mubu_text="%3Cspan%3ESWOT%EF%BC%88%E9%9D%99%E6%80%81%E5%88%86%E6%9E%90%E6%B3%95%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
        <outline text="针对某一件事、某一个时间点的某个状态进行分析（点）" _mubu_text="%3Cspan%20class=%22bold%22%3E%E9%92%88%E5%AF%B9%E6%9F%90%E4%B8%80%E4%BB%B6%E4%BA%8B%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22bold%22%3E%E6%9F%90%E4%B8%80%E4%B8%AA%E6%97%B6%E9%97%B4%E7%82%B9%3C/span%3E%3Cspan%3E%E7%9A%84%3C/span%3E%3Cspan%20class=%22bold%22%3E%E6%9F%90%E4%B8%AA%E7%8A%B6%E6%80%81%3C/span%3E%3Cspan%3E%E8%BF%9B%E8%A1%8C%E5%88%86%E6%9E%90%EF%BC%88%E7%82%B9%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
        <outline text="自己（优势、劣势）" _mubu_text="%3Cspan%3E%E8%87%AA%E5%B7%B1%EF%BC%88%E4%BC%98%E5%8A%BF%E3%80%81%E5%8A%A3%E5%8A%BF%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
          <outline text="企业、自身内部的 ---&gt; 自己可以改变" _mubu_text="%3Cspan%3E%E4%BC%81%E4%B8%9A%E3%80%81%E8%87%AA%E8%BA%AB%E5%86%85%E9%83%A8%E7%9A%84%20---&amp;gt;%20%E8%87%AA%E5%B7%B1%E5%8F%AF%E4%BB%A5%E6%94%B9%E5%8F%98%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="外部（机会、威胁）" _mubu_text="%3Cspan%3E%E5%A4%96%E9%83%A8%EF%BC%88%E6%9C%BA%E4%BC%9A%E3%80%81%E5%A8%81%E8%83%81%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
          <outline text="存在于企业的外部的你无法施加影响的因素" _mubu_text="%3Cspan%3E%E5%AD%98%E5%9C%A8%E4%BA%8E%E4%BC%81%E4%B8%9A%E7%9A%84%E5%A4%96%E9%83%A8%E7%9A%84%E4%BD%A0%E6%97%A0%E6%B3%95%E6%96%BD%E5%8A%A0%E5%BD%B1%E5%93%8D%E7%9A%84%E5%9B%A0%E7%B4%A0%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="" _mubu_text="" _note="" _mubu_note="" _mubu_images="%5B%7B%22id%22%3A%22vQyeXKGNrl%22%2C%22oh%22%3A1552%2C%22ow%22%3A1680%2C%22uri%22%3A%22document_image%2F31398412_e3f40002-32da-467f-d9b2-e82ed8c227d4.jpg%22%2C%22w%22%3A400%7D%5D"/>
      </outline>
    </outline>
    <outline text="六、企业人员组织构成" _mubu_text="%3Cspan%3E%E5%85%AD%E3%80%81%E4%BC%81%E4%B8%9A%E4%BA%BA%E5%91%98%E7%BB%84%E7%BB%87%E6%9E%84%E6%88%90%3C/span%3E" _note="" _mubu_note="">
      <outline text="1、企业主" _mubu_text="%3Cspan%3E1%E3%80%81%E4%BC%81%E4%B8%9A%E4%B8%BB%3C/span%3E" _note="" _mubu_note="">
        <outline text="业主是企业的灵魂和核心" _mubu_text="%3Cspan%3E%E4%B8%9A%E4%B8%BB%E6%98%AF%E4%BC%81%E4%B8%9A%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%E7%81%B5%E9%AD%82%3C/span%3E%3Cspan%3E%E5%92%8C%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%E6%A0%B8%E5%BF%83%3C/span%3E" _note="" _mubu_note=""/>
        <outline text="结合实际思考：" _mubu_text="%3Cspan%3E%E7%BB%93%E5%90%88%E5%AE%9E%E9%99%85%E6%80%9D%E8%80%83%EF%BC%9A%3C/span%3E" _note="" _mubu_note="">
          <outline text="①在企业中所花时间最多的是什么" _mubu_text="%3Cspan%3E%E2%91%A0%E5%9C%A8%E4%BC%81%E4%B8%9A%E4%B8%AD%E6%89%80%E8%8A%B1%E6%97%B6%E9%97%B4%E6%9C%80%E5%A4%9A%E7%9A%84%E6%98%AF%E4%BB%80%E4%B9%88%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="②你认为业主最重要的工作是什么" _mubu_text="%3Cspan%3E%E2%91%A1%E4%BD%A0%E8%AE%A4%E4%B8%BA%E4%B8%9A%E4%B8%BB%E6%9C%80%E9%87%8D%E8%A6%81%E7%9A%84%E5%B7%A5%E4%BD%9C%E6%98%AF%E4%BB%80%E4%B9%88%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="老板类型" _mubu_text="%3Cspan%3E%E8%80%81%E6%9D%BF%E7%B1%BB%E5%9E%8B%3C/span%3E" _note="" _mubu_note="">
          <outline text="工匠型" _mubu_text="%3Cspan%3E%E5%B7%A5%E5%8C%A0%E5%9E%8B%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="英雄型" _mubu_text="%3Cspan%3E%E8%8B%B1%E9%9B%84%E5%9E%8B%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="干预型" _mubu_text="%3Cspan%3E%E5%B9%B2%E9%A2%84%E5%9E%8B%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="策略型" _mubu_text="%3Cspan%3E%E7%AD%96%E7%95%A5%E5%9E%8B%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
      </outline>
      <outline text="2、企业合伙人" _mubu_text="%3Cspan%3E2%E3%80%81%E4%BC%81%E4%B8%9A%E5%90%88%E4%BC%99%E4%BA%BA%3C/span%3E" _note="" _mubu_note="">
        <outline text="找什么样的合伙人？" _mubu_text="%3Cspan%20class=%22bold%20text-color-purple%22%3E%E6%89%BE%E4%BB%80%E4%B9%88%E6%A0%B7%E7%9A%84%E5%90%88%E4%BC%99%E4%BA%BA%EF%BC%9F%3C/span%3E" _note="" _mubu_note="">
          <outline text="缺少资金" _mubu_text="%3Cspan%3E%E7%BC%BA%E5%B0%91%E8%B5%84%E9%87%91%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="缺少技术或者技能" _mubu_text="%3Cspan%3E%E7%BC%BA%E5%B0%91%E6%8A%80%E6%9C%AF%E6%88%96%E8%80%85%E6%8A%80%E8%83%BD%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="缺少销售能力或者渠道" _mubu_text="%3Cspan%3E%E7%BC%BA%E5%B0%91%E9%94%80%E5%94%AE%E8%83%BD%E5%8A%9B%E6%88%96%E8%80%85%E6%B8%A0%E9%81%93%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="缺乏管理能力" _mubu_text="%3Cspan%3E%E7%BC%BA%E4%B9%8F%E7%AE%A1%E7%90%86%E8%83%BD%E5%8A%9B%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="合伙人相处之道" _mubu_text="%3Cspan%3E%E5%90%88%E4%BC%99%E4%BA%BA%E7%9B%B8%E5%A4%84%E4%B9%8B%E9%81%93%3C/span%3E" _note="" _mubu_note="">
          <outline text="设置合理的利益分配结构" _mubu_text="%3Cspan%3E%E8%AE%BE%E7%BD%AE%E5%90%88%E7%90%86%E7%9A%84%E5%88%A9%E7%9B%8A%E5%88%86%E9%85%8D%E7%BB%93%E6%9E%84%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="相互之间一定要透明、陈恳，己所不欲勿施于人" _mubu_text="%3Cspan%3E%E7%9B%B8%E4%BA%92%E4%B9%8B%E9%97%B4%E4%B8%80%E5%AE%9A%E8%A6%81%E9%80%8F%E6%98%8E%E3%80%81%E9%99%88%E6%81%B3%EF%BC%8C%E5%B7%B1%E6%89%80%E4%B8%8D%E6%AC%B2%E5%8B%BF%E6%96%BD%E4%BA%8E%E4%BA%BA%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="" _mubu_text="" _note="" _mubu_note=""/>
        </outline>
      </outline>
      <outline text="3、员工" _mubu_text="%3Cspan%3E3%E3%80%81%E5%91%98%E5%B7%A5%3C/span%3E" _note="" _mubu_note="">
        <outline text="如果没有时间或者能力，去完成所有的工作，那就要雇人。初创微小企业只需要1-2和临时工就好" _mubu_text="%3Cspan%3E%E5%A6%82%E6%9E%9C%E6%B2%A1%E6%9C%89%E6%97%B6%E9%97%B4%E6%88%96%E8%80%85%E8%83%BD%E5%8A%9B%EF%BC%8C%E5%8E%BB%E5%AE%8C%E6%88%90%E6%89%80%E6%9C%89%E7%9A%84%E5%B7%A5%E4%BD%9C%EF%BC%8C%E9%82%A3%E5%B0%B1%E8%A6%81%E9%9B%87%E4%BA%BA%E3%80%82%E5%88%9D%E5%88%9B%E5%BE%AE%E5%B0%8F%E4%BC%81%E4%B8%9A%E5%8F%AA%E9%9C%80%E8%A6%811-2%E5%92%8C%E4%B8%B4%E6%97%B6%E5%B7%A5%E5%B0%B1%E5%A5%BD%3C/span%3E" _note="" _mubu_note=""/>
        <outline text="" _mubu_text="" _note="" _mubu_note=""/>
      </outline>
      <outline text="还需要哪些人？" _mubu_text="%3Cspan%3E%E8%BF%98%E9%9C%80%E8%A6%81%E5%93%AA%E4%BA%9B%E4%BA%BA%EF%BC%9F%3C/span%3E" _note="" _mubu_note="">
        <outline text="企业顾问" _mubu_text="%3Cspan%3E%E4%BC%81%E4%B8%9A%E9%A1%BE%E9%97%AE%3C/span%3E" _note="" _mubu_note="">
          <outline text="顾问包括：有关协会专业人员、会计师、银行家、律师、咨询顾问、政府部门等" _mubu_text="%3Cspan%3E%E9%A1%BE%E9%97%AE%E5%8C%85%E6%8B%AC%EF%BC%9A%E6%9C%89%E5%85%B3%E5%8D%8F%E4%BC%9A%E4%B8%93%E4%B8%9A%E4%BA%BA%E5%91%98%E3%80%81%E4%BC%9A%E8%AE%A1%E5%B8%88%E3%80%81%E9%93%B6%E8%A1%8C%E5%AE%B6%E3%80%81%E5%BE%8B%E5%B8%88%E3%80%81%E5%92%A8%E8%AF%A2%E9%A1%BE%E9%97%AE%E3%80%81%E6%94%BF%E5%BA%9C%E9%83%A8%E9%97%A8%E7%AD%89%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
      </outline>
      <outline text="根据自己的判断，形成自己企业的法律形态" _mubu_text="%3Cspan%3E%E6%A0%B9%E6%8D%AE%E8%87%AA%E5%B7%B1%E7%9A%84%E5%88%A4%E6%96%AD%EF%BC%8C%E5%BD%A2%E6%88%90%E8%87%AA%E5%B7%B1%E4%BC%81%E4%B8%9A%E7%9A%84%E6%B3%95%E5%BE%8B%E5%BD%A2%E6%80%81%3C/span%3E" _note="" _mubu_note=""/>
    </outline>
    <outline text="" _mubu_text="" _note="" _mubu_note="">
      <outline text="学法、知法、懂法、守法、用法" _mubu_text="%3Cspan%20class=%22text-color-red%22%3E%E5%AD%A6%E6%B3%95%E3%80%81%E7%9F%A5%E6%B3%95%E3%80%81%E6%87%82%E6%B3%95%E3%80%81%E5%AE%88%E6%B3%95%E3%80%81%E7%94%A8%E6%B3%95%3C/span%3E" _note="" _mubu_note=""/>
      <outline text="在劳动合同期限内解除劳动合同" _mubu_text="%3Cspan%3E%E5%9C%A8%E5%8A%B3%E5%8A%A8%E5%90%88%E5%90%8C%E6%9C%9F%E9%99%90%E5%86%85%E8%A7%A3%E9%99%A4%E5%8A%B3%E5%8A%A8%E5%90%88%E5%90%8C%3C/span%3E" _note="" _mubu_note="">
        <outline text="提前一个月告知公司" _mubu_text="%3Cspan%3E%E6%8F%90%E5%89%8D%E4%B8%80%E4%B8%AA%E6%9C%88%E5%91%8A%E7%9F%A5%E5%85%AC%E5%8F%B8%3C/span%3E" _note="" _mubu_note=""/>
        <outline text="试用期期间提前三天告知公司，提交辞职报告" _mubu_text="%3Cspan%3E%E8%AF%95%E7%94%A8%E6%9C%9F%E6%9C%9F%E9%97%B4%E6%8F%90%E5%89%8D%E4%B8%89%E5%A4%A9%E5%91%8A%E7%9F%A5%E5%85%AC%E5%8F%B8%EF%BC%8C%E6%8F%90%E4%BA%A4%E8%BE%9E%E8%81%8C%E6%8A%A5%E5%91%8A%3C/span%3E" _note="" _mubu_note=""/>
        <outline text="签了两次固定期限后第三次无论是否为固定期限都为无固定期限劳动合成" _mubu_text="%3Cspan%3E%E7%AD%BE%E4%BA%86%E4%B8%A4%E6%AC%A1%E5%9B%BA%E5%AE%9A%E6%9C%9F%E9%99%90%E5%90%8E%E7%AC%AC%E4%B8%89%E6%AC%A1%E6%97%A0%E8%AE%BA%E6%98%AF%E5%90%A6%E4%B8%BA%E5%9B%BA%E5%AE%9A%E6%9C%9F%E9%99%90%E9%83%BD%E4%B8%BA%E6%97%A0%E5%9B%BA%E5%AE%9A%E6%9C%9F%E9%99%90%E5%8A%B3%E5%8A%A8%E5%90%88%E6%88%90%3C/span%3E" _note="" _mubu_note=""/>
      </outline>
      <outline text="（一）了解企业的法律环境" _mubu_text="%3Cspan%3E%EF%BC%88%E4%B8%80%EF%BC%89%E4%BA%86%E8%A7%A3%E4%BC%81%E4%B8%9A%E7%9A%84%E6%B3%95%E5%BE%8B%E7%8E%AF%E5%A2%83%3C/span%3E" _note="" _mubu_note="">
        <outline text="" _mubu_text="" _note="" _mubu_note=""/>
      </outline>
    </outline>
  </body>
</opml>